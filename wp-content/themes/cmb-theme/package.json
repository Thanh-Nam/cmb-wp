{
  "name": "cmb-theme",
  "version": "1.0.0",
  "description": "CMB WordPress Theme — SCSS build",
  "scripts": {
    "dev": "sass --watch assets/scss/main.scss:assets/css/main.css --style expanded --source-map",
    "build": "sass assets/scss/main.scss:assets/css/main.css --style compressed --no-source-map && sed -i 's/^\\xEF\\xBB\\xBF//' assets/css/main.css"
  },
  "devDependencies": {
    "sass": "^1.77.4"
  }
}
